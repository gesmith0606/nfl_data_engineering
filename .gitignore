
# NFL Data Engineering Project .gitignore

# Environment and Secrets
.env
*.env
!.env.example

# AWS and Credentials
aws-credentials.json
*.pem
*.key

# Data files (large datasets)
data/*
!data/gold/
*.parquet
*.csv
*.json
# TD-02 (Phase 75): allow web/frontend JSON config files (package.json, tsconfig.json,
# package-lock.json, vitest.config files written as JSON, etc.) to ship via git so
# CI + fresh clones get vitest deps.
!web/frontend/**/*.json
logs/
temp/

# System files
.DS_Store
Thumbs.db
*.pkg
AWSCLIV2.pkg

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Python
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Frontend lib/ holds source; don't let the Python packaging rule swallow it.
!web/frontend/src/lib/
!web/frontend/src/lib/**
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   This is especially recommended for binary packages to ensure reproducibility, and is more
#   commonly ignored for libraries.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm stores project-wide configurations in .pdm.toml, but it is recommended to not include it
#   in version control.
#   https://pdm.fming.dev/#use-with-ide
.pdm.toml

# PEP 582; used by e.g. github.com/David-OConnor/pyflow and github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be added to the global gitignore or merged into this project gitignore.  For a PyChromeDriver
#  local working directory, uncomment the next line!
#.idea/

# Databricks
.databricks/

# AWS credentials
.aws/

# Environment variables
.env
.env.local
.env.*.local

# Data files
*.parquet
*.csv
*.json
!.mcp.json.example
!.vscode/mcp.json
# Holdout-use ledger must be durable in git — it records sealed-gate
# evaluations so holdout erosion is visible across clones/reviewers.
!.planning/holdout_ledger.json
# Model artifacts must be durable in git: the broad *.json/*.parquet rules
# silently blocked xgb_*.json + metadata.json + OOF parquets when the
# ensemble was "restored" (TD-09 class — load_ensemble() crashes on a
# fresh checkout without them). The sanity checker's artifact-integrity
# check enforces the full set.
!models/ensemble/
!models/ensemble/**
!models/quantile/
!models/quantile/**
models/quantile/_backup_leaky/
# Ship-gate verdict JSONs (top-level of models/player/ only — the heavy
# XGB artifacts in the position subdirs stay ignored; the v4.3 router
# never loads them: QB is forced SKIP, RB respects SKIP, WR/TE promote
# to HYBRID via the committed models/residual metas). Without the report
# the router silently falls back to full heuristic — this is why the
# 2026-07-02 GHA smoke test never produced projection_source='hybrid'.
!models/player/*.json
# Re-allow web/frontend JSON config (TD-02). The allowlist on line ~23 is
# overridden by the broader *.json rule above; this restores it after the
# data-files block. Without this, package-lock.json is untracked and the
# GHA `Setup Node.js` step fails to resolve cache-dependency-path.
!web/frontend/**/*.json
data/*
!data/gold/
data/gold/*
!data/gold/projections/
!data/gold/projections/**
# Allow parquet files specifically inside data/gold/projections
!data/gold/projections/**/*.parquet
!data/gold/predictions/
!data/gold/predictions/**
# Allow parquet files specifically inside data/gold/predictions
!data/gold/predictions/**/*.parquet
# Sentiment pipeline: allow Gold parquet + Silver/Bronze JSON so Railway
# can serve news/team-events without a live cron run
!data/gold/sentiment/
!data/gold/sentiment/**
!data/gold/sentiment/**/*.parquet
!data/silver/
!data/silver/sentiment/
!data/silver/sentiment/**
!data/silver/sentiment/**/*.json
# Matchups page: /api/teams/{team}/defense-metrics needs Silver
# defense+SoS parquets. Without these the matchups page returns
# `{team: null, positional: []}` and the entire matchup-advantage
# core renders empty. ~13 MB.
!data/silver/defense/
!data/silver/defense/**
!data/silver/defense/**/*.parquet
!data/silver/teams/
!data/silver/teams/**
!data/silver/teams/**/*.parquet
!data/bronze/
!data/bronze/sentiment/
!data/bronze/sentiment/**
!data/bronze/sentiment/**/*.json
# Player rosters: commit Bronze parquet so PlayerNameResolver works on the
# GHA runner during daily-sentiment.yml (v7.1 fix for Phase 69 blocker).
# Railway Dockerfile already bundles these; this adds them to git too.
!data/bronze/players/
!data/bronze/players/rosters/
!data/bronze/players/rosters/**
!data/bronze/players/rosters/**/*.parquet
!data/bronze/players/rosters_live/
!data/bronze/players/rosters_live/**
!data/bronze/players/rosters_live/**/*.parquet
# Phase 75.1: 2025 rookies for DQAL-03 (sanity check requires path exists).
!data/bronze/players/rookies/
!data/bronze/players/rookies/**
!data/bronze/players/rookies/**/*.parquet
!data/bronze/depth_charts/
!data/bronze/depth_charts/**
!data/bronze/depth_charts/**/*.parquet
# External projections (Sleeper/ESPN/Yahoo-via-FP): the weekly-external-
# projections workflow has been committing NOTHING since launch — its git-add
# was silently swallowed by the broad *.parquet ignore (TD-09 class, third
# occurrence). The website's yahoo rankings column reads the Bronze
# yahoo_proxy_fp parquet as its fallback tier (FP's v2 API now 403s without
# an auth token), and the consensus-grading backtests read the Silver tables.
!data/bronze/external_projections/
!data/bronze/external_projections/**
!data/bronze/external_projections/**/*.parquet
!data/silver/external_projections/
!data/silver/external_projections/**
!data/silver/external_projections/**/*.parquet
# Schedules: required by web/Dockerfile (COPY data/bronze/schedules/) — the
# Railway image won't build without these. Same pattern as rosters/depth_charts
# above. /api/teams/current-week, /api/teams/{team}/roster default-week
# resolution, predictions, and lineups all 503 without this data.
!data/bronze/schedules/
!data/bronze/schedules/**
!data/bronze/schedules/**/*.parquet
# Matchup player ratings (2026-07): the roster API's per-player Madden
# ratings read EA OVRs from madden_ratings and fall back to PFR seasonal
# defense stat percentiles. Both are COPY'd by web/Dockerfile — without
# these committed the Railway build breaks (TD-09 class) and the matchup
# tab silently degrades to team-anchor ratings. ~1 MB total.
!data/bronze/madden_ratings/
!data/bronze/madden_ratings/**
!data/bronze/madden_ratings/**/*.parquet
!data/bronze/pfr/
!data/bronze/pfr/seasonal/
!data/bronze/pfr/seasonal/def/
!data/bronze/pfr/seasonal/def/**
!data/bronze/pfr/seasonal/def/**/*.parquet
# Phase 1.4 (Live Odds Capture): The Odds API snapshots committed so the
# open/close proxy history accumulates in git (TD-08/09 pattern).
# Each 2×/daily GHA cron run appends one parquet; the full season history
# is needed for true CLV evaluation (Phase 2.4).
!data/bronze/odds_api/
!data/bronze/odds_api/**
!data/bronze/odds_api/**/*.parquet

# External rankings cache (ADVR-03): commit the Sleeper/FantasyPros/ESPN JSON
# so compareExternalRankings never returns empty on first deploy.
!data/external/
!data/external/*.json

# Test fixtures (Plan 71-02): allow recorded Bronze + Claude JSON so the
# FakeClaudeClient replay harness and LLM-03 benchmark can read them in CI.
!tests/fixtures/
!tests/fixtures/**
!tests/fixtures/**/*.json

# Logs
*.log
logs/

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.vercel

# Phase 75 audit: artifacts from /dashboard/leagues live test
.playwright-mcp/
live-*.png

# GSD transient/runtime artifacts (never commit — worktrees alone is 267 MB)
.claude/worktrees/
.claude/gsd-pristine/
.claude/gsd-pre-update-backup-*/
.claude/scheduled_tasks.lock

# Stray frontend tooling scaffolding — NOT used by web/Dockerfile (verified:
# Dockerfile COPYs only src/, web/api/, web/__init__.py, data/*; never web/frontend/).
# Frontend deploys via Vercel. Placed after the TD-02 !web/frontend/**/*.json
# allowlist so these override it (last-match-wins).
web/frontend/.claude/
web/frontend/.agents/skills/shadcn/evals/
web/frontend/.agents/skills/tanstack-query/skill-rules-fragment.json
web/frontend/.oxfmtrc.json
web/frontend/.oxlintrc.json
web/frontend/.vscode/
web/frontend/skills-lock.json


# Ephemeral grading reports — CI writes these on the runner and never commits them
output/grading/
