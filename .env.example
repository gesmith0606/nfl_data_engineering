# Environment variables for NFL Data Engineering Pipeline

# AWS Configuration
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# S3 Bucket Configuration - Your NFL Data Engineering Buckets
S3_BUCKET_BRONZE=nfl-raw
S3_BUCKET_SILVER=nfl-refined  
S3_BUCKET_GOLD=nfl-trusted

# Databricks Configuration
DATABRICKS_WORKSPACE_URL=https://dbc-c9b1be11-c0c8.cloud.databricks.com
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_TOKEN=your-databricks-token

# NFL Data Configuration
DEFAULT_SEASON=2024
DEFAULT_WEEK=1

# Pipeline week override — used by the GitHub Actions cron job and the health
# check script to bypass the auto-computed NFL week.  Format: "YYYY:WW"
# Example: PIPELINE_WEEK_OVERRIDE=2024:10
# Leave blank to use auto-computation from the current date.
PIPELINE_WEEK_OVERRIDE=

# Health check freshness threshold (days).
# Files older than this value trigger a WARN in check_pipeline_health.py.
# The GitHub Actions workflow uses the default of 8 days (covers Mon–Tue gap).
HEALTH_CHECK_MAX_AGE_DAYS=8

# Logging Configuration
LOG_LEVEL=INFO
