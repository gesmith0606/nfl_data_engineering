#!/bin/sh
#
# Pre-commit hook for automated code review
# 
# This hook runs the git-code-reviewer agent before every commit
# to ensure code quality and apply automatic fixes.

echo "🔍 Running automated pre-commit code review..."

# Get the project root directory
PROJECT_ROOT=$(git rev-parse --show-toplevel)

# ── Credential scan ────────────────────────────────────────────────────────
echo "🔒 Scanning for credentials in staged files..."

CREDENTIAL_FOUND=0

# Patterns that indicate a hardcoded credential value
CRED_PATTERNS='AKIA[0-9A-Z]{16}|ghp_[0-9a-zA-Z]{36}|github_pat_[0-9a-zA-Z_]{82}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----'

# Check staged files only (not working tree)
STAGED_FILES=$(git diff --cached --name-only)

for FILE in $STAGED_FILES; do
    # Skip binary files and .env.example (which has placeholder values)
    case "$FILE" in
        *.png|*.jpg|*.gif|*.ico|*.pdf|*.parquet|*.env.example) continue ;;
    esac

    # Check the staged content of the file (not the working tree version)
    if git show ":$FILE" 2>/dev/null | grep -qE "$CRED_PATTERNS"; then
        echo "❌ Credential pattern detected in staged file: $FILE"
        CREDENTIAL_FOUND=1
    fi
done

if [ $CREDENTIAL_FOUND -eq 1 ]; then
    echo ""
    echo "🚫 Commit blocked: potential credentials found in staged files."
    echo "   Remove the credentials and use environment variables instead."
    echo "   If this is a false positive, review the flagged file above."
    exit 1
fi

echo "✅ No credentials detected in staged files."
# ── End credential scan ────────────────────────────────────────────────────

# Path to automated code review script
REVIEW_SCRIPT="$PROJECT_ROOT/.claude/workflows/automated-code-review.py"

# Check if the review script exists
if [ ! -f "$REVIEW_SCRIPT" ]; then
    echo "❌ Code review script not found at $REVIEW_SCRIPT"
    echo "Run: cp .claude/git-hooks/pre-commit .git/hooks/pre-commit"
    exit 1
fi

# Make sure the script is executable
chmod +x "$REVIEW_SCRIPT"

# Run the automated code review
echo "📋 Analyzing staged changes..."
python3 "$REVIEW_SCRIPT"

# Capture exit code
REVIEW_EXIT_CODE=$?

# Handle different exit codes
case $REVIEW_EXIT_CODE in
    0)
        echo "✅ Code review passed! Proceeding with commit."
        ;;
    1)
        echo "❌ Critical issues found! Commit blocked."
        echo ""
        echo "Please fix the critical issues above before committing."
        echo "You can also run the review manually:"
        echo "  python3 .claude/workflows/automated-code-review.py"
        exit 1
        ;;
    2)
        echo "⚠️  Code review passed with warnings."
        echo ""
        echo "Consider addressing the warnings above."
        echo "Commit will proceed in 5 seconds... (Ctrl+C to cancel)"
        sleep 5
        echo "✅ Proceeding with commit despite warnings."
        ;;
    *)
        echo "❌ Code review system error (exit code: $REVIEW_EXIT_CODE)"
        echo "Review the logs above and try again."
        exit 1
        ;;
esac

# Stage any auto-fixed files
git add -u

echo "🚀 Pre-commit review completed successfully!"
exit 0