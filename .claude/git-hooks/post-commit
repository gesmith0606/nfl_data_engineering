#!/bin/sh
#
# Post-commit hook for tracking code quality metrics
# 
# This hook runs after a successful commit to track
# code quality trends and generate reports.

echo "📊 Running post-commit quality tracking..."

# Get the project root directory and commit info
PROJECT_ROOT=$(git rev-parse --show-toplevel)
COMMIT_HASH=$(git rev-parse HEAD)
COMMIT_MESSAGE=$(git log -1 --pretty=format:"%s")

# Path to automated code review script
REVIEW_SCRIPT="$PROJECT_ROOT/.claude/workflows/automated-code-review.py"

# Check if the review script exists
if [ ! -f "$REVIEW_SCRIPT" ]; then
    echo "⚠️  Code review script not found, skipping quality tracking"
    exit 0
fi

# Run post-commit analysis
echo "🔍 Analyzing commit $COMMIT_HASH..."
echo "📝 Message: $COMMIT_MESSAGE"

# Run review on the committed changes
python3 "$REVIEW_SCRIPT" "$COMMIT_HASH" > /dev/null 2>&1

# Generate quality report
REVIEW_DIR="$PROJECT_ROOT/.claude/review_history"
if [ -d "$REVIEW_DIR" ]; then
    LATEST_REVIEW=$(ls -t "$REVIEW_DIR"/*.json 2>/dev/null | head -1)
    if [ -n "$LATEST_REVIEW" ]; then
        echo "📈 Quality metrics saved to: $(basename "$LATEST_REVIEW")"
    fi
fi

# Check if we should generate a trend report (every 10th commit)
COMMIT_COUNT=$(git rev-list --count HEAD)
if [ $((COMMIT_COUNT % 10)) -eq 0 ]; then
    echo "🎯 Milestone: $COMMIT_COUNT commits reached!"
    echo "📊 Consider reviewing quality trends in .claude/review_history/"
fi

echo "✅ Post-commit tracking completed!"
exit 0